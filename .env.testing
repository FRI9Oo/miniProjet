################################################################################
# TESTING ENVIRONMENT CONFIGURATION
# This file is used when running tests (phpunit)
# Copy from .env.example and override for test-specific settings
################################################################################

APP_NAME=Laravel
APP_ENV=testing
# Generate a key with: php artisan key:generate
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4
BCRYPT_ROUNDS=4

################################################################################
# LOGGING
################################################################################
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

################################################################################
# DATABASE - Use SQLite in-memory for fast tests
################################################################################
DB_CONNECTION=mysql
DB_DATABASE=:memory:

################################################################################
# SESSION & CACHE - Use array driver for testing (no persistence needed)
################################################################################
SESSION_DRIVER=array
CACHE_STORE=array
QUEUE_CONNECTION=sync

################################################################################
# BROADCAST & FILESYSTEM
################################################################################
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

################################################################################
# MAIL - Use array driver to capture emails without sending
################################################################################
MAIL_MAILER=array

################################################################################
# REDIS & MEMCACHED - Optional, not typically needed for tests
################################################################################
MEMCACHED_HOST=127.0.0.1
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

################################################################################
# VITE
################################################################################
VITE_APP_NAME="${APP_NAME}"
